{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "opensearch-mcp",
  "version": "0.1.0",
  "description": "MCP server with web_search and web_fetch tools.",
  "keywords": [
    "ai",
    "mcp",
    "modelcontextprotocol",
    "search",
    "websearch"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "opensearch-mcp": "out/index.js"
  },
  "files": [
    "out"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@mozilla/readability": "^0.5.0",
    "cheerio": "^1.0.0",
    "jsdom": "^26.0.0",
    "p-retry": "^6.2.1",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^0.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@changesets/cli": "^2.30.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.4.0",
    "typescript": "^5.9.0",
    "ultracite": "7.5.9",
    "vitest": "^3.1.0"
  }
}
