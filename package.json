{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "opensearch-mcp",
  "version": "0.1.1",
  "description": "MCP server with web_search and web_fetch tools.",
  "keywords": [
    "ai",
    "mcp",
    "modelcontextprotocol",
    "search",
    "websearch"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "opensearch-mcp": "out/index.js"
  },
  "files": [
    "out"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "jsdom": "^29.0.2",
    "p-retry": "^8.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "^2.30.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "ultracite": "7.5.9",
    "vitest": "^4.1.4"
  }
}
