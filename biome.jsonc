{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/vitest"],
  "files": {
    "includes": ["!packages/**/src/__tests__/fixtures"]
  },
  "overrides": [
    {
      "includes": ["packages/opensearch/src/index.ts"],
