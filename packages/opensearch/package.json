{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "@minpeter/opensearch",
  "version": "0.0.1",
  "description": "Reusable web search and page fetch runtime for TypeScript clients",
  "keywords": [
    "ai",
    "fetch",
    "search",
    "websearch"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/opensearch-mcp.git",
    "directory": "packages/opensearch"
  },
  "type": "module",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "out"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary --exclude 'src/__tests__/integration.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "jsdom": "^29.1.1",
    "p-retry": "^8.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  }
}
